<div class="row justify-content-center mt-5 mb-5">
  <div class="col-md-6 col-lg-5">
    <div class="card shadow-sm border-0">
      <div class="card-body p-5">
        <h3 class="text-center mb-4 fw-bold">⚖️ Crear Cuenta</h3>
        <p class="text-center text-muted mb-4">Únete a Docketwise Pro y gestiona tus expedientes</p>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <div class="mb-3">
            <%= f.label :email, "Correo Electrónico", class: "form-label fw-bold" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control form-control-lg", placeholder: "tu@firma.com" %>
          </div>

          <div class="mb-3">
            <%= f.label :password, class: "form-label fw-bold" %>
            <% if @minimum_password_length %>
            <span class="text-muted small">(Mínimo <%= @minimum_password_length %> caracteres)</span>
            <% end %>
            <%= f.password_field :password, autocomplete: "new-password", class: "form-control form-control-lg", placeholder: "Crea una contraseña segura" %>
          </div>

          <div class="mb-4">
            <%= f.label :password_confirmation, "Confirmar Contraseña", class: "form-label fw-bold" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control form-control-lg", placeholder: "Repite tu contraseña" %>
          </div>

          <div class="d-grid">
            <%= f.submit "Registrarme", class: "btn btn-success btn-lg fw-bold" %>
          </div>
        <% end %>

        <div class="text-center mt-4 pt-3 border-top">
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
  </div>
</div>