<div class="row justify-content-center mt-5">
  <div class="col-md-6 col-lg-4">
    <div class="card shadow-sm border-0">
      <div class="card-body p-5">
        <h3 class="text-center mb-4 fw-bold">⚖️ Docketwise Pro</h3>
        <p class="text-center text-muted mb-4">Inicia sesión en tu cuenta segura</p>

        <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
          <div class="mb-3">
            <%= f.label :email, "Correo Electrónico", class: "form-label fw-bold" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control form-control-lg", placeholder: "abogado@firma.com" %>
          </div>

          <div class="mb-4">
            <%= f.label :password, "Contraseña", class: "form-label fw-bold" %>
            <%= f.password_field :password, autocomplete: "current-password", class: "form-control form-control-lg", placeholder: "********" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="form-check mb-4">
              <%= f.check_box :remember_me, class: "form-check-input" %>
              <%= f.label :remember_me, "Recordar mi sesión", class: "form-check-label text-muted" %>
            </div>
          <% end %>

          <div class="d-grid">
            <%= f.submit "Entrar al Sistema", class: "btn btn-primary btn-lg fw-bold" %>
          </div>
        <% end %>

        <div class="text-center mt-4 pt-3 border-top">
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
  </div>
</div>