<% if @solicitantes.any? %>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-5 fw-bold text-dark">Expedientes Legales</h1>
    <%= link_to "➕ Nuevo Solicitante", new_solicitante_path, class: "btn btn-primary shadow-sm" %>
  </div>

  <div class="card shadow-sm">
    <div class="card-body p-0">
      <table class="table table-hover table-striped mb-0">
        <thead class="table-dark">
          <tr>
            <th>Nombre del Cliente</th>
            <th>Email de Contacto</th>
            <th>Estado</th>
            <th class="text-center">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% @solicitantes.each do |solicitante| %>
            <tr>
              <td class="align-middle fw-bold"><%= solicitante.nombre %></td>
              <td class="align-middle"><%= solicitante.email %></td>
              
              <td class="align-middle">
                <% if solicitante.aprobado %>
                  <span class="badge bg-success">Aprobado</span>
                <% else %>
                  <span class="badge bg-warning text-dark">Pendiente</span>
                <% end %>
              </td>

              <td class="align-middle text-center">
                <%= link_to "Ver Perfil", solicitante, class: "btn btn-sm btn-outline-info" %>
                <%= link_to "Editar", edit_solicitante_path(solicitante), class: "btn btn-sm btn-outline-secondary" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

<% else %>

  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-8 text-center py-5 bg-white rounded shadow-sm border-0">
        <div class="mb-4" style="font-size: 5rem;">📇</div>
        
        <h2 class="fw-bold text-dark mb-3">Tu bóveda está vacía</h2>
        <p class="text-muted fs-5 mb-4 px-md-5">
          Aún no tienes expedientes registrados bajo tu cuenta. ¡Comienza a construir tu portafolio legal hoy mismo!
        </p>
        
        <%= link_to "➕ Crear mi primer expediente", new_solicitante_path, class: "btn btn-primary btn-lg fw-bold shadow-sm px-4 py-3" %>
      </div>
    </div>
  </div>

<% end %>